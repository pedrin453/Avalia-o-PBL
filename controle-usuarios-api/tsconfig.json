{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "moduleResolution": "nodenext",
    "types": ["node"],

    "resolveJsonModule": true
  },

  "include": [
    "src",
    "prisma"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}