{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],
    "resolveJsonModule": true
  },

  "include": [
    "src",
    "prisma"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts"
  ]
}